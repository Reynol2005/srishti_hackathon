# ─── Supabase ───────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...   # use the SERVICE ROLE key (not anon)

# ─── Twilio ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890                          # your Twilio sender number

# ─── Optional ──────────────────────────────────────────────
DRY_RUN=false                                            # set true to log messages without sending
